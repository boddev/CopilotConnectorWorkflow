# CopilotConnectorWorkflow setup configuration. Copy to setup\.env and edit.
# All values are optional; the script prompts for anything missing.

# ── Sibling repository sources ──────────────────────────────────────────────
# Where to clone the dependent repos. Defaults are the boddev forks.
EVALUATIONCLI_REPO=https://github.com/boddev/EvaluationCLI.git
DATA_ENHANCER_REPO=https://github.com/boddev/data-enhancer.git
COPILOT_CONNECTOR_SKILL_REPO=https://github.com/boddev/CopilotConnectorSkill.git

# Branch / ref to check out (default: main)
EVALUATIONCLI_REF=main
DATA_ENHANCER_REF=main
COPILOT_CONNECTOR_SKILL_REF=main

# ── Logins ──────────────────────────────────────────────────────────────────
# Microsoft 365 tenant ID where M365 Copilot / Graph auth happens (Step 1 LLM
# provider, optional Step 6 agent calls). Leave blank to prompt interactively.
M365_TENANT_ID=

# Azure tenant + subscription where you intend to deploy the connector.
# These can differ from the M365 tenant.
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_ID=

# ── Optional behavior switches ──────────────────────────────────────────────
# Set true to accept the @microsoft/m365-copilot-eval EULA during setup.
ACCEPT_M365_EVAL_EULA=false

# Set true to install missing tools (node, python, git, azure-cli) via winget.
INSTALL_MISSING_TOOLS=true
