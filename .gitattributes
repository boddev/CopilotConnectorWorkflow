# Default LF for text — keeps Node-rendered template parity stable
# across Windows checkouts (Opus I5, Phase 0).
* text=auto eol=lf

# Templates rendered by the C# port must match the Node renderer's
# byte-verbatim behavior for non-`.hbs` files. Pinning EOLs here so a
# Windows clone never silently converts CRLF before MSBuild's
# EmbeddedResource step picks templates up.
templates/** text eol=lf
winui3/src/Ccw.Templates/Resources/** text eol=lf

# Snapshot fixtures are compared byte-for-byte against Node output;
# any conversion would produce false positives.
winui3/tests/**/Fixtures/** text eol=lf
winui3/tests/**/Snapshots/** text eol=lf

# Binary template assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.zip  binary
*.pfx  binary
*.appx binary
*.msix binary

# Windows-specific scripts should stay CRLF.
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.ps1  text eol=crlf

# Visual Studio + WinUI XAML / csproj / sln formats expect CRLF.
*.csproj   text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.sln      text eol=crlf
*.slnx     text eol=crlf
*.xaml     text eol=crlf
*.manifest text eol=crlf
*.appxmanifest text eol=crlf
