<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 mp rescap">

  <Identity
    Name="CopilotConnectorWorkflow.WinUI"
    Publisher="CN=CopilotConnectorWorkflow"
    Version="0.1.0.0" />

  <mp:PhoneIdentity PhoneProductId="11111111-1111-1111-1111-111111111111" PhonePublisherId="00000000-0000-0000-0000-000000000000"/>

  <Properties>
    <DisplayName>Copilot Connector Workflow</DisplayName>
    <PublisherDisplayName>CopilotConnectorWorkflow</PublisherDisplayName>
    <Logo>Assets\Packaging\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="x-generate"/>
  </Resources>

  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="$targetentrypoint$">
      <uap:VisualElements
        DisplayName="Copilot Connector Workflow"
        Description="Generate, deploy, and score Microsoft 365 Copilot Connectors."
        BackgroundColor="#202020"
        Square150x150Logo="Assets\Packaging\Square150x150Logo.png"
        Square44x44Logo="Assets\Packaging\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Packaging\Wide310x150Logo.png"/>
        <uap:SplashScreen Image="Assets\Packaging\SplashScreen.png"/>
      </uap:VisualElements>
      <Extensions>
        <!-- Plan §5g: optional .ccwjob file association. Disabled (commented) in v1.
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="ccwjob">
            <uap:SupportedFileTypes>
              <uap:FileType>.ccwjob</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>CCW Job</uap:DisplayName>
          </uap:FileTypeAssociation>
        </uap:Extension>
        -->
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust"/>
  </Capabilities>
</Package>
