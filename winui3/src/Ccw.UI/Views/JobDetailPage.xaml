<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.JobDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Ccw.UI.ViewModels">
    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.JobId, Mode=OneWay}"
                   FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,4,0,12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8"
                    VerticalAlignment="Center">
            <Button Content="Run pipeline" Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.RunPipelineCommand}"
                    IsEnabled="{x:Bind ViewModel.CanRun, Mode=OneWay}"/>
            <Button Content="Cancel"
                    Command="{x:Bind ViewModel.CancelCommand}"
                    Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay}"/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsRunning, Mode=OneWay}"
                          Width="20" Height="20"/>
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" VerticalAlignment="Center"/>
            <TextBlock Text="{x:Bind ViewModel.CreatedAt, Mode=OneWay}" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <Button Content="Refresh" Command="{x:Bind ViewModel.RefreshCommand}"
                    IsEnabled="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource NegateBool}, FallbackValue=True}"/>
        </StackPanel>

        <InfoBar Grid.Row="3" IsOpen="True" IsClosable="False" Severity="Informational"
                 Margin="0,0,0,12"
                 Message="{x:Bind ViewModel.RunHint, Mode=OneWay}"/>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.Steps}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:StepViewModel">
                        <Expander HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                  HorizontalContentAlignment="Stretch">
                            <Expander.Header>
                                <Grid ColumnDefinitions="*,Auto,Auto" MinWidth="400">
                                    <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind Status, Mode=OneWay}"
                                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind Timing, Mode=OneWay}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                </Grid>
                            </Expander.Header>
                            <StackPanel Spacing="8" Padding="0,4">
                                <InfoBar IsOpen="{x:Bind HasError, Mode=OneWay}" IsClosable="False"
                                         Severity="Error"
                                         Message="{x:Bind ErrorMessage, Mode=OneWay}"/>
                                <TextBox Text="{x:Bind Output, Mode=OneWay}"
                                         Visibility="{x:Bind HasOutput, Mode=OneWay}"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                                         FontFamily="Consolas, Cascadia Code" FontSize="12"
                                         MaxHeight="280"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                                <TextBlock Text="No output yet."
                                           Visibility="{x:Bind HasOutput, Mode=OneWay, Converter={StaticResource NegateBool}}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                           FontStyle="Italic"/>
                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
