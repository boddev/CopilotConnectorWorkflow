<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.JobDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Ccw.Core.Models">
    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="{x:Bind ViewModel.JobId, Mode=OneWay}"
                   FontSize="22" FontWeight="SemiBold"/>
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.Description, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,4,0,12"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"/>
            <TextBlock Text="{x:Bind ViewModel.CreatedAt, Mode=OneWay}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
            <Button Click="Refresh_Click">Refresh</Button>
        </StackPanel>

        <Grid Grid.Row="3" ColumnDefinitions="*,*">
            <ListView Grid.Column="0" ItemsSource="{x:Bind ViewModel.Steps}" Margin="0,0,8,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:StepRecord">
                        <Grid Padding="8,6" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Text="{x:Bind Name}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="{x:Bind Status}" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <ListView Grid.Column="1" ItemsSource="{x:Bind ViewModel.LogLines}" Margin="8,0,0,0">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock Text="{x:Bind}" FontFamily="Consolas, Cascadia Code" FontSize="12"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
