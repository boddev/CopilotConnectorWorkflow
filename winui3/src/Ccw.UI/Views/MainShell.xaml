<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.MainShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <NavigationView
        x:Name="Nav"
        PaneDisplayMode="Left"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        SelectionChanged="Nav_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Jobs" Tag="jobs">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8FD;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="New job" Tag="new">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE710;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Compare" Tag="compare">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8AB;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemSeparator/>
            <NavigationViewItem Content="Diagnostics" Tag="diag">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9F5;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>
        <Frame x:Name="ContentFrame"/>
    </NavigationView>
</Page>
