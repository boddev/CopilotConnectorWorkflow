<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.JobsListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Ccw.Core.Models">
    <Grid Padding="24" RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Column="0" Text="Jobs" FontSize="22" FontWeight="SemiBold"/>
            <Button Grid.Column="1" Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
        </Grid>
        <ListView Grid.Row="1"
                  x:Name="JobsList"
                  IsItemClickEnabled="True"
                  ItemClick="Jobs_ItemClick"
                  ItemsSource="{x:Bind ViewModel.Jobs}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:JobRecord">
                    <Grid Padding="8,6" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                        <FontIcon Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                  Glyph="&#xE7C3;" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind Id}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{x:Bind CreatedAt}" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                   Text="{x:Bind Status}" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
