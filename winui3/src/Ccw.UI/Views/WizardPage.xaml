<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.WizardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Ccw.UI.ViewModels">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="First-run setup" Style="{ThemeResource TitleTextBlockStyle}"/>
            <TextBlock TextWrapping="Wrap" Style="{ThemeResource BodyTextBlockStyle}"
                       Text="Check that the external CLIs CCW shells out to are installed. Install missing ones, then optionally clone the sibling repositories (EvaluationCLI, CopilotConnectorSkill) into your src folder."/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12">
            <Button Content="Refresh" Command="{x:Bind ViewModel.RefreshCommand}" IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource NegateBool}, FallbackValue=True}"/>
            <Button Content="Install missing (winget)" Command="{x:Bind ViewModel.InstallMissingCommand}" IsEnabled="{x:Bind ViewModel.CanInstall, Mode=OneWay, FallbackValue=False}"/>
            <Button Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}" IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay, FallbackValue=False}"/>
        </StackPanel>

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Rows}" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:WizardProbeRow">
                    <Grid Padding="12" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{x:Bind Probe.DisplayName}" Style="{ThemeResource SubtitleTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind Status, Mode=OneWay}" Opacity="0.8"/>
                            <TextBlock Text="{x:Bind Probe.Path, Mode=OneTime, FallbackValue=''}" Opacity="0.5" FontSize="11"/>
                        </StackPanel>
                        <ProgressRing Grid.Column="1" IsActive="{x:Bind Busy, Mode=OneWay}" Width="18" Height="18"/>
                        <HyperlinkButton Grid.Column="2"
                                         NavigateUri="{x:Bind ManualLink, Mode=OneTime, FallbackValue=''}"
                                         Content="Docs"
                                         Visibility="{x:Bind HasManualLink, Mode=OneTime}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12">
            <CheckBox Content="Clone sibling repos" IsChecked="{x:Bind ViewModel.CloneSiblings, Mode=TwoWay}"/>
            <TextBox PlaceholderText="src root" Text="{x:Bind ViewModel.SrcRoot, Mode=TwoWay}" Width="420"/>
            <Button Content="Clone &amp; build" Command="{x:Bind ViewModel.CloneSiblingsCommand}" IsEnabled="{x:Bind ViewModel.CanClone, Mode=OneWay, FallbackValue=False}"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="{x:Bind ViewModel.ProgressText, Mode=OneWay}" Opacity="0.7" TextWrapping="Wrap"/>

        <InfoBar Grid.Row="5"
                 IsOpen="{x:Bind ViewModel.AllSatisfied, Mode=OneWay}"
                 Severity="Success"
                 Title="Setup complete"
                 Message="Every dependency is present. You can close the wizard and start a job."
                 IsClosable="True"/>
    </Grid>
</Page>
