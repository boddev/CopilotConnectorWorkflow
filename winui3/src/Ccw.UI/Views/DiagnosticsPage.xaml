<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:boot="using:Ccw.Bootstrap">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="Diagnostics" FontSize="22" FontWeight="SemiBold"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,12,0,12">
            <Button Click="Refresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    <TextBlock Text="Probe dependencies"/>
                </StackPanel>
            </Button>
            <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="18" Height="18"/>
        </StackPanel>
        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Probes}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="boot:DependencyProbeResult">
                    <Grid Padding="8,6" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*">
                        <FontIcon Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                  Glyph="&#xE73E;" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{x:Bind Name}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                            <Run Text="present: "/>
                            <Run Text="{x:Bind Present}"/>
                            <Run Text="  |  version: "/>
                            <Run Text="{x:Bind Version}"/>
                            <Run Text="  |  "/>
                            <Run Text="{x:Bind RequiredAction}"/>
                        </TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
