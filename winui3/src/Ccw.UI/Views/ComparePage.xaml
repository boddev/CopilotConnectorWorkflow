<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Ccw.UI.Views.ComparePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0" Text="Compare jobs" FontSize="22" FontWeight="SemiBold"/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" Margin="0,12,0,12">
            <ComboBox x:Name="JobABox" PlaceholderText="Job A" Width="260" DisplayMemberPath="Id"
                      SelectionChanged="JobABox_SelectionChanged"/>
            <ComboBox x:Name="JobBBox" PlaceholderText="Job B" Width="260" DisplayMemberPath="Id"/>
            <Button Content="Run compare" Click="RunCompare_Click"/>
            <Button Content="Refresh" Click="Refresh_Click"/>
        </StackPanel>
        <RichTextBlock x:Name="ReportBlock" Grid.Row="2"/>
    </Grid>
</Page>
