//
//   Use npm run enhance with --focus-on-eval and a checkpoint file to track last-crawl time.
//   See sample_codes/agents-toolkit/data-source.ts in the skill bundle for a complete example.

import * as fs from 'fs';
import * as path from 'path';
import * as crypto from 'crypto';
import { enhance, EnhancementError, ExternalItem, RawItem } from './enhancer';

export type { ExternalItem, RawItem };

export interface DataSource {
  /** Yields pre-enhanced ExternalItems (seed data path). */
  fetchItems(): AsyncIterable<ExternalItem>;
  /** Yields raw source items (live data path). */
  fetchRawItems(): AsyncIterable<RawItem>;
}

/** Reads raw JSON/JSONL records from a file or directory tree. */
export class JsonlDataSource implements DataSource {
  constructor(
    private readonly sourcePath: string,
    private readonly aclMode: 'everyone' | 'everyoneExceptGuests' | 'none' = 'everyone'
  ) {}

  async *fetchItems(): AsyncIterable<ExternalItem> {
    for await (const rawItem of this.fetchRawItems()) {
      if (isExternalItem(rawItem)) {
        yield rawItem;
        continue;
      }
      yield enhance(rawItem, this.aclMode);
    }
  }

  async *fetchRawItems(): AsyncIterable<RawItem> {
    const files = discoverJsonFiles(this.sourcePath);
    for (const file of files) {
      let index = 0;
      for await (const record of readJsonRecords(file)) {
        yield ensureRawItemId(record, file, index++);
      }
    }
  }
}

function discoverJsonFiles(sourcePath: string): string[] {
  const abs = path.isAbsolute(sourcePath) ? sourcePath : path.resolve(process.cwd(), sourcePath);
  if (!fs.existsSync(abs)) throw new Error(`Data source path not found: ${abs}`);

  const stat = fs.statSync(abs);
  if (stat.isFile()) {
    assertJsonLikeFile(abs);
    return [abs];
  }

  const files: string[] = [];
  const walk = (dir: string): void => {
    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
      const full = path.join(dir, entry.name);
      if (entry.isDirectory()) {
        walk(full);
      } else if (entry.isFile() && isJsonLikeFile(full)) {
        files.push(full);
      }
    }
  };
  walk(abs);
  if (files.length === 0) throw new Error(`No .json or .jsonl files found under data source path: ${abs}`);
  return files.sort();
}

function assertJsonLikeFile(filePath: string): void {
  if (!isJsonLikeFile(filePath)) {
    throw new Error(`Unsupported data source file: ${filePath}. Expected .json or .jsonl.`);
  }
}

function isJsonLikeFile(filePath: string): boolean {
  const ext = path.extname(filePath).toLowerCase();
  return ext === '.json' || ext === '.jsonl';
}

async function* readJsonRecords(filePath: string): AsyncIterable<RawItem> {
  const ext = path.extname(filePath).toLowerCase();
  if (ext === '.json') {
    const content = stripBom(fs.readFileSync(filePath, 'utf-8'));
    try {
      const parsed = JSON.parse(content) as unknown;
      if (Array.isArray(parsed)) {
        for (const item of parsed) yield asRawItem(item);
      } else {
        yield asRawItem(parsed);
      }
      return;
    } catch {
      // Many exports use .json for newline-delimited JSON records.
    }
  }

  const fd = fs.openSync(filePath, 'r');
  const buffer = Buffer.allocUnsafe(1024 * 1024);
  let carry = '';
  let firstLine = true;
  try {
    while (true) {
      const bytesRead = fs.readSync(fd, buffer, 0, buffer.length, null);
      if (bytesRead === 0) break;
      const text = carry + buffer.subarray(0, bytesRead).toString('utf-8');
      const lines = text.split(/\r?\n/);
      carry = lines.pop() || '';
      for (let line of lines) {
        if (firstLine) {
          line = stripBom(line);
          firstLine = false;
        }
        const trimmed = line.trim();
        if (trimmed) yield asRawItem(JSON.parse(trimmed) as unknown);
      }
    }
    const trimmed = (firstLine ? stripBom(carry) : carry).trim();
    if (trimmed) yield asRawItem(JSON.parse(trimmed) as unknown);
  } finally {
    fs.closeSync(fd);
  }
}

function asRawItem(value: unknown): RawItem {
  if (!value || typeof value !== 'object' || Array.isArray(value)) {
    throw new Error(`Expected a JSON object record, got: ${JSON.stringify(value)}`);
  }
  return value as RawItem;
}

function isExternalItem(value: RawItem): value is RawItem & ExternalItem {
  return !!value &&
    typeof value.id === 'string' &&
    Array.isArray(value.acl) &&
    !!value.properties &&
    typeof value.properties === 'object' &&
    !!value.content &&
    typeof value.content === 'object' &&
    typeof (value.content as { value?: unknown }).value === 'string';
}

function ensureRawItemId(item: RawItem, filePath: string, index: number): RawItem {
  if (typeof item.id === 'string' && item.id.trim()) return item;
  const candidate = firstString(item, ['duns', 'DUNS', 'recordId', 'recordID', 'id', 'ID', 'primaryName', 'name']);
  return {
    ...item,
    id: candidate ? toSafeItemId(candidate) : stableFallbackId(filePath, index),
  };
}

function firstString(item: RawItem, keys: string[]): string {
  for (const key of keys) {
    const value = item[key];
    if (typeof value === 'string' && value.trim()) return value.trim();
    if (typeof value === 'number' && Number.isFinite(value)) return String(value);
  }
  return '';
}

function toSafeItemId(value: string): string {
  const cleaned = value.trim().replace(/[/?#&\\]+/g, '-').replace(/[^A-Za-z0-9._~-]+/g, '_');
  if (cleaned.length > 0 && cleaned.length <= 120) return cleaned;
  const hash = crypto.createHash('sha256').update(value, 'utf-8').digest('hex').slice(0, 24);
  return `item-${hash}`;
}

function stableFallbackId(filePath: string, index: number): string {
  const hash = crypto.createHash('sha256').update(`${filePath}\u001f${index}`, 'utf-8').digest('hex').slice(0, 24);
  return `item-${hash}`;
}

function stripBom(value: string): string {
  return value.charCodeAt(0) === 0xfeff ? value.slice(1) : value;
}

export function defaultDataSource(): DataSource {
  const aclMode = (process.env.ACL_MODE as 'everyone' | 'everyoneExceptGuests' | 'none') || '{{aclMode}}';
  const dataPath = process.env.DATA_SOURCE_PATH || './data/enhanced-items.jsonl';
  return new JsonlDataSource(dataPath, aclMode);
}
